# =====================================================
# CONTROL DE INVENTARIOS - Variables de Entorno
# =====================================================
# Copia este archivo como .env y ajusta los valores

# === Base de Datos ===
POSTGRES_DB=control_inventarios
POSTGRES_USER=ci_user
POSTGRES_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql+asyncpg://ci_user:your_secure_password_here@localhost:5432/control_inventarios

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === Seguridad ===
SECRET_KEY=generate-a-256-bit-random-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=7

# === Entorno ===
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# === API ===
API_V1_PREFIX=/api/v1
PROJECT_NAME=Control de Inventarios
VERSION=1.0.0

# === CORS ===
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# === Almacenamiento ===
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# === SAP Integration ===
SAP_HOST=your-sap-host
SAP_PORT=443
SAP_CLIENT=100
SAP_USER=your-sap-user
SAP_PASSWORD=your-sap-password
SAP_SYSTEM_ID=PRD
SAP_ENABLED=false

# === Frontend ===
VITE_API_URL=http://localhost:8000/api/v1
VITE_APP_NAME=Control de Inventarios
VITE_APP_VERSION=1.0.0
